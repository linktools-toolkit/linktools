{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/linktools-toolkit/linktools/master/linktools/src/linktools/assets/schemas/linktools-project-v1.schema.json",
  "title": "Linktools project manifest (v1)",
  "description": "A .linktools.json project manifest. Core only understands this generic envelope; each capability (cntr, ai, ...) interprets its own components.<name> block.",
  "type": "object",
  "required": ["schema_version", "kind"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "linktools-project"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "requires": {
      "$ref": "#/$defs/requires"
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/component"
      }
    },
    "metadata": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "requires": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "component": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "requires": {
          "$ref": "#/$defs/requires"
        },
        "config": {
          "type": "object"
        },
        "metadata": {
          "type": "object"
        },
        "extensions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  }
}
