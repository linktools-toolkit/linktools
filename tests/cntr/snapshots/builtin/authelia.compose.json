{
  "networks": {
    "authelia": {
      "name": "aio-authelia"
    },
    "lldap": {
      "name": "aio-lldap"
    },
    "nginx": {
      "name": "aio-nginx"
    }
  },
  "services": {
    "authelia": {
      "command": [
        "authelia",
        "--config=/config/configuration.yml",
        "--config=/config/configuration.acl.yml",
        "--config=/config/configuration.2fa.yml",
        "--config=/config/configuration.oidc.yml"
      ],
      "container_name": "aio-authelia",
      "depends_on": [
        "authelia-redis"
      ],
      "environment": [
        "AUTHELIA_LOG_LEVEL=debug",
        "AUTHELIA_SESSION_SECRET_FILE=/secrets/session_secret",
        "AUTHELIA_STORAGE_ENCRYPTION_KEY_FILE=/secrets/storage_encryption_key",
        "AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET_FILE=/secrets/jwt_secret",
        "AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET_FILE=/secrets/oidc_hmac_secret",
        "AUTHELIA_AUTHENTICATION_BACKEND_LDAP_ADDRESS=ldap://lldap:3890",
        "AUTHELIA_AUTHENTICATION_BACKEND_LDAP_BASE_DN=dc=_",
        "AUTHELIA_AUTHENTICATION_BACKEND_LDAP_USER=uid=admin,ou=people,dc=_",
        "AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD_FILE=/secrets/authentication_backend_ldap_password",
        "X_AUTHELIA_CONFIG_FILTERS=template"
      ],
      "hostname": "authelia",
      "image": "authelia/authelia:latest",
      "logging": {
        "driver": "json-file",
        "options": {
          "max-size": "10m"
        }
      },
      "networks": {
        "authelia": null,
        "lldap": null,
        "nginx": null
      },
      "restart": "unless-stopped",
      "volumes": [
        "<APP_DATA>/authelia/config:/config",
        "<APP_DATA>/authelia/secrets:/secrets:ro"
      ]
    },
    "authelia-admin": {
      "container_name": "aio-authelia-admin",
      "depends_on": [
        "authelia"
      ],
      "environment": [
        "AAD_LOGLEVEL=DEBUG",
        "AAD_AUTHELIA_DOMAIN=_:0",
        "AAD_AUTHELIA_COOKIE_NAME=aio-auth-session",
        "AAD_AUTHELIA_MIN_AUTH_LEVEL=1",
        "AAD_DIRECTORY_TYPE=lldap-graphql",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_ENDPOINT=http://lldap:17170/api/graphql",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_USER=admin",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_PASSWORD=snapval",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_LDAP_HOST=lldap",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_LDAP_PORT=3890",
        "AAD_DIRECTORY_LLDAP_GRAPHQL_LDAP_BASE_DN=dc=_",
        "TRUSTED_ORIGINS=https://_:0",
        "NODE_TLS_REJECT_UNAUTHORIZED=0"
      ],
      "hostname": "authelia-admin",
      "image": "ghcr.io/asalimonov/authelia-admin:latest",
      "logging": {
        "driver": "json-file",
        "options": {
          "max-size": "10m"
        }
      },
      "networks": {
        "authelia": null,
        "lldap": null,
        "nginx": null
      },
      "restart": "unless-stopped",
      "user": "root",
      "volumes": [
        "<APP_DATA>/authelia/config:/config",
        "<APP_DATA>/authelia/secrets:/secrets:ro"
      ]
    },
    "authelia-redis": {
      "container_name": "aio-authelia-redis",
      "hostname": "authelia-redis",
      "image": "redis:alpine",
      "logging": {
        "driver": "json-file",
        "options": {
          "max-size": "10m"
        }
      },
      "networks": {
        "authelia": null
      },
      "restart": "unless-stopped",
      "volumes": [
        "<APP_DATA>/authelia/redis/data:/data"
      ]
    }
  }
}