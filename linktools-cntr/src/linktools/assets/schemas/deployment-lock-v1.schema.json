{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/linktools-toolkit/linktools/master/linktools-cntr/assets/schemas/deployment-lock-v1.schema.json",
  "title": "linktools-cntr deployment lock (v1)",
  "description": "container.lock.json -- a local, not-committed-downstream record of what a deployment's inputs and generated outputs are (repo revisions, manifest hashes, installed containers, generated artifact hashes). Never contains config plaintext, secrets, env values, or running state.",
  "type": "object",
  "required": ["schema_version", "project", "linktools_cntr", "repositories", "containers", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "string"
    },
    "linktools_cntr": {
      "type": "string"
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "type", "reproducible"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["git", "local"]
          },
          "branch": {
            "type": ["string", "null"]
          },
          "revision": {
            "type": ["string", "null"]
          },
          "manifest_sha256": {
            "type": ["string", "null"]
          },
          "manifest_version": {
            "type": ["string", "null"]
          },
          "definitions_sha256": {
            "type": ["string", "null"]
          },
          "reproducible": {
            "type": "boolean"
          }
        }
      }
    },
    "containers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "services"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "repository_url": {
            "type": ["string", "null"]
          },
          "services": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "sha256"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["compose", "dockerfile"]
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    }
  }
}
