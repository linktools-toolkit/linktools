{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/linktools-toolkit/linktools/master/linktools-cntr/assets/schemas/repository-v1.schema.json",
  "title": "linktools-cntr repository manifest (v1)",
  "description": "Static, declarative manifest a linktools-cntr repository may place at its root as .linktools.json. Never fetched or interpreted at runtime -- for IDE/CI use only.",
  "type": "object",
  "required": ["schema_version", "kind"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "linktools-cntr-repository"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "requires": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    },
    "extensions": {
      "type": "object"
    }
  }
}
